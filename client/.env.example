# Copy this file to `.env.local` or `.env` if you want to override the WebSocket host.
# Leave it unset to use the current origin.
# Format: host[:port] without a protocol prefix.

# Example for local backend development:
# VITE_WS_URL=127.0.0.1:8080

# Example for a deployed backend:
# VITE_WS_URL=samether-dev-alb-1995571399.ap-northeast-1.elb.amazonaws.com