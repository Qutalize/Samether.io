# Samezario Server Configuration
# Copy this file to .env and customize for your environment

# Redis Configuration (optional - if not set, in-memory leaderboard is used)
REDIS_ADDR=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=samezario:leaderboard

# Room Configuration
ROOM_ID=samezario-room-1
ROOM_CAPACITY=50
INSTANCE_ID=

# Server Configuration
PORT=8080

# AWS Location Service (Phase 2+)
AWS_REGION=ap-northeast-1
LOCATION_TRACKER_NAME=samether-dev-tracker
LOCATION_MAP_NAME=samether-dev-map
LOCATION_MAP_API_KEY=

# Development Settings
# LOG_LEVEL=debug
# ENABLE_CORS=true
